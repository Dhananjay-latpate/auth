# Server Configuration
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# MongoDB Connection
# Local: mongodb://localhost:27017/rauth
# Railway (use the MONGO_URL or MONGODB_URL variable provided by the Railway MongoDB plugin):
MONGO_URI=mongodb://localhost:27017/rauth

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# API URL (used for OAuth callback URLs)
API_URL=http://localhost:5000

# App Name (used in 2FA QR codes)
APP_NAME=Rauth

# Email Configuration (SMTP)
FROM_EMAIL=noreply@example.com
FROM_NAME=Rauth Auth Service
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_EMAIL=your_smtp_user@ethereal.email
SMTP_PASSWORD=your_smtp_password

# OAuth - Google (optional)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub (optional)
# Get credentials from: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
